    "@lingui/vite-plugin": "^5.3.2",
    "@types/aws-lambda": "8.10.157",
    "@types/node": "^24.10.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
