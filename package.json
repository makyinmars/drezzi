{
  "name": "drezzi",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "bun run lint && bun run lingui:compile && vite build && tsc --noEmit",
    "start": "bun .output/server/index.mjs",
    "check": "npx ultracite check",
    "check:all": "bun typecheck && bun run check",
    "ci:check": "npx ultracite check --diagnostic-level error",
    "ci:format": "npx ultracite check",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:pull": "bunx prisma db pull",
    "db:seed": "bunx prisma db seed",
    "db:studio": "bun prisma studio",
    "db:reset": "bunx prisma migrate reset",
    "doctor": "npx ultracite doctor",
    "format": "npx ultracite fix",
    "format:unsafe": "npx ultracite fix --unsafe",
    "lint": "npx ultracite check",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "sso": "aws sso login --sso-session=engineering",
    "lingui:extract": "lingui extract --clean",
    "lingui:compile": "lingui compile"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.44",
    "@aws-sdk/client-s3": "^3.943.0",
    "@aws-sdk/client-sqs": "^3.943.0",
