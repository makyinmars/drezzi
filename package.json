    "@hookform/resolvers": "^5.1.1",
    "@lingui/core": "^5.3.2",
    "@lingui/react": "^5.3.2",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@radix-ui/react-dialog": "^1.1.14",
